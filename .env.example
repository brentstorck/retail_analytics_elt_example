# Copy to .env and adjust as needed. The loader (pipeline/) and dbt both read DUCKDB_PATH,
# so they must agree on it. Use an ABSOLUTE path to avoid surprises about the working dir.

# Where the DuckDB warehouse file lives.
DUCKDB_PATH=C:\path\to\retail-analytics-platform\warehouse\retail.duckdb

# Where raw downloads are cached.
DATA_DIR=C:\path\to\retail-analytics-platform\data

# dbt: where to find profiles.yml (this repo ships one inside retail_dbt/).
DBT_PROFILES_DIR=C:\path\to\retail-analytics-platform\retail_dbt
